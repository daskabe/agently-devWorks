{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build VS Code Extension",
      "type": "shell",
      "command": "pnpm build --filter agently-vscode-extension",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Run Demo App",
      "type": "shell",
      "command": "pnpm dev --filter demo-react-app",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        },
        "pattern": {
          "regexp": "^.*$"
        }
      }
    }
  ]
}

{
  "name": "agently-vscode-extension",
  "displayName": "Agently",
  "description": "Developer productivity bridge for prompt-driven code edits.",
  "version": "0.1.0",
  "publisher": "agently",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agently.openSettings",
    "onCommand:agently.openPromptPanel",
    "onCommand:agently.applyQueuedPrompt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agently.openPromptPanel",
        "title": "Agently: Open Prompt Panel"
      },
      {
        "command": "agently.applyQueuedPrompt",
        "title": "Agently: Apply Next Queued Prompt"
      },
      {
        "command": "agently.openSettings",
        "title": "Agently: Open Settings"
      }
    ],
    "configuration": {
      "title": "Agently",
      "properties": {
        "agently.bridgePort": {
          "type": "number",
          "default": 43110,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local HTTP port used by browser integrations to send prompt payloads."
        },
        "agently.autoOpenPanelOnPrompt": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open/focus the Agently panel when a prompt arrives from the local bridge."
        },
        "agently.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show VS Code information notifications for Agently events (e.g. prompt received, bridge started)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "dev": "node esbuild.js --watch",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prebuild:prod": "pnpm run clean && pnpm run typecheck",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major",
    "prepackage": "pnpm run build:prod"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}

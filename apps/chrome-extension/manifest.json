{
  "manifest_version": 3,
  "name": "Agently Local Prompt Bridge",
  "version": "0.1.0",
  "description": "Shift+right-click any element, send an LLM prompt + DOM context to local VS Code bridge.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Agently"
  }
}
